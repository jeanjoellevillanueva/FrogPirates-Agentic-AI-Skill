#!/usr/bin/env bash
#
# Run voiceover opening validation on staged script changes.
#

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
VALIDATOR="$REPO_ROOT/scripts/validate-voiceover-openings.sh"

if [ ! -x "$VALIDATOR" ]; then
  echo "pre-commit: validator not executable — run: chmod +x scripts/validate-voiceover-openings.sh"
  exit 1
fi

staged_scripts=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^scripts/.*-script\.md$' || true)

if [ -z "$staged_scripts" ]; then
  exit 0
fi

echo "pre-commit: checking voiceover openings..."
exec "$VALIDATOR"
